<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_DIR" value="/var/log/xenticate"/>

    <!-- ================================================================ -->
    <!-- Console — startup and INFO events                                 -->
    <!-- ================================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================ -->
    <!-- Main application log — INFO and above (daily rolling, 30 days)   -->
    <!-- ================================================================ -->
    <appender name="APP_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/thales-lb-app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/thales-lb-app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>50MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================ -->
    <!-- DEBUG log — all DEBUG and above for HSM LB classes               -->
    <!-- ================================================================ -->
    <appender name="DEBUG_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/thales-lb-debug.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/thales-lb-debug.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>7</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================ -->
    <!-- PAYLOAD log — hex dump of every request and response             -->
    <!-- Separate file so it can be toggled on/off without restart        -->
    <!-- Toggle: set hsm.lb.payload.log.enabled=true in application.props -->
    <!-- ================================================================ -->
    <appender name="PAYLOAD_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/thales-lb-payload.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/thales-lb-payload.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>200MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <!-- Keep only 3 days — payload logs grow fast -->
            <maxHistory>3</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================ -->
    <!-- Health check log — separate so health probes don't flood main log -->
    <!-- ================================================================ -->
    <appender name="HEALTH_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/thales-lb-health.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/thales-lb-health.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================ -->
    <!-- Logger assignments                                                -->
    <!-- ================================================================ -->

    <!-- All HSM LB classes → DEBUG_LOG + APP_LOG -->
    <logger name="com.isc.hsm.transparentlb" level="DEBUG" additivity="false">
        <appender-ref ref="DEBUG_LOG"/>
        <appender-ref ref="APP_LOG"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Payload logger — dedicated logger called from PassthroughHandler -->
    <logger name="com.isc.hsm.transparentlb.PAYLOAD" level="DEBUG" additivity="false">
        <appender-ref ref="PAYLOAD_LOG"/>
    </logger>

    <!-- Health checker → its own file, not cluttering main log -->
    <logger name="com.isc.hsm.transparentlb.health" level="DEBUG" additivity="false">
        <appender-ref ref="HEALTH_LOG"/>
        <appender-ref ref="APP_LOG"/>
    </logger>

    <!-- Spring and ActiveMQ — INFO only -->
    <logger name="org.springframework" level="INFO" additivity="false">
        <appender-ref ref="APP_LOG"/>
    </logger>
    <logger name="org.apache.activemq" level="WARN" additivity="false">
        <appender-ref ref="APP_LOG"/>
    </logger>

    <!-- Root -->
    <root level="INFO">
        <appender-ref ref="APP_LOG"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
